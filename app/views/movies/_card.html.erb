<div class="bg-white rounded-lg">
  <% if current_user %>
    <%= render "movies/favorite_button", movie: movie %>
  <% end %>
  <%= link_to movie_path(movie), data: { turbo_frame: "_top" } do %>
    <div class="p-4">
      <div class="h-48 w-full">
        <%= image_tag(movie.poster_url, class: "h-full w-full rounded-lg object-contain") %>
      </div>
      <hr class="mt-8 border-gray-400">
      <div class="mt-2 flex justify-between items-center">
        <p class="font-semibold text-2xl"><%= movie.title || movie.original_title %></p>
      </div>
      <% if movie.release_date %>
        <p class="mt-1 font-medium text-lg"><%= movie.release_date.year %></p>
      <% end %>
    </div>
  <% end %>
</div>
